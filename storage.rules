rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User-uploaded PDFs (past papers, syllabuses)
    match /resources/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Diagram pool — images uploaded by Admin SDK import script.
    // All authenticated users can read; no client-side writes.
    match /diagrams/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
