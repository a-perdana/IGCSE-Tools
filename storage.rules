rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User-uploaded PDFs (past papers, syllabuses)
    match /resources/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Diagram pool — imported by Admin SDK or uploaded via the Diagram Library UI.
    // All authenticated users can read and write.
    match /diagrams/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
